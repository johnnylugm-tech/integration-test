{
  "version": "1.0",
  "created_at": "2026-07-01",
  "phase": 2,
  "project": "taskq",
  "layers": [
    {
      "name": "cli",
      "modules": [
        "taskq.__main__"
      ],
      "allowed_dependencies": [
        "service",
        "store"
      ]
    },
    {
      "name": "service",
      "modules": [
        "taskq.executor"
      ],
      "allowed_dependencies": [
        "store"
      ]
    },
    {
      "name": "store",
      "modules": [
        "taskq.store",
        "taskq.redact",
        "taskq.validation",
        "taskq.models",
        "taskq.config"
      ],
      "allowed_dependencies": []
    }
  ],
  "dependencies": {
    "cli": [
      "service",
      "store"
    ],
    "service": [
      "store"
    ]
  },
  "quality_targets": {
    "max_complexity": 10,
    "min_coverage": 95,
    "max_coupling": 0.3
  },
  "nfr_dimension_mapping": {
    "NFR-01": "performance",
    "NFR-02": "security",
    "NFR-03": "error_handling"
  },
  "nfr_traceability": {
    "NFR-01": {
      "type": "performance",
      "target": "p95 < 50ms (warm-process, submit+status over 100 iters, excluding subprocess)",
      "module": "taskq.store"
    },
    "NFR-02": {
      "type": "security",
      "target": "shell=True forbidden codebase-wide; injection blacklist ( ; | & $ > < ` ) covered by tests",
      "module": "taskq.executor"
    },
    "NFR-03": {
      "type": "reliability",
      "target": "atomic tasks.json write via tmp+os.replace; stdout/stderr redaction before persist",
      "module": "taskq.redact"
    }
  },
  "advisory_only": [],
  "gate_score_overrides": {
    "performance": 75.0,
    "security": 80.0,
    "error_handling": 80.0
  },
  "fr_module_traceability": {
    "FR-01": "taskq.models",
    "FR-02": "taskq.executor",
    "FR-03": "taskq.__main__"
  },
  "architecture_constraints": [
    "no_circular_dependencies"
  ],
  "high_risk_modules": [
    "taskq.executor",
    "taskq.store"
  ]
}