{
  "version": "1.0",
  "created_at": "2026-06-29",
  "phase": 2,
  "project": "taskq",
  "layers": [
    {
      "name": "cli",
      "modules": [
        "taskq.cli.__main__",
        "taskq.cli.cli",
        "taskq.cli.formatting"
      ],
      "allowed_dependencies": [
        "runner",
        "io",
        "core"
      ]
    },
    {
      "name": "runner",
      "modules": [
        "taskq.runner.runner"
      ],
      "allowed_dependencies": [
        "io",
        "core"
      ]
    },
    {
      "name": "io",
      "modules": [
        "taskq.io.store",
        "taskq.io.redaction"
      ],
      "allowed_dependencies": [
        "core"
      ]
    },
    {
      "name": "core",
      "modules": [
        "taskq.core.config",
        "taskq.core.models",
        "taskq.core.validation"
      ],
      "allowed_dependencies": []
    }
  ],
  "dependencies": {
    "cli": [
      "runner",
      "io",
      "core"
    ],
    "runner": [
      "io",
      "core"
    ],
    "io": [
      "core"
    ]
  },
  "quality_targets": {
    "max_complexity": 10,
    "min_coverage": 90,
    "max_coupling": 0.3
  },
  "nfr_dimension_mapping": {
    "NFR-01": "performance",
    "NFR-02": "security",
    "NFR-03": "error_handling"
  },
  "nfr_traceability": {
    "NFR-01": {
      "type": "performance",
      "target": ">= p95 < 50ms",
      "module": "taskq.cli.cli"
    },
    "NFR-02": {
      "type": "security",
      "target": ">= 0 shell=True call sites; blacklist all 7 chars",
      "module": "taskq.runner.runner"
    },
    "NFR-03": {
      "type": "reliability",
      "target": ">= atomic write + 100% redaction pre-persist",
      "module": "taskq.io.store"
    }
  },
  "advisory_only": [],
  "gate_score_overrides": {
    "performance": 75.0,
    "security": 80.0,
    "error_handling": 80.0
  },
  "fr_module_traceability": {
    "FR-01": "taskq.core.validation",
    "FR-02": "taskq.runner.runner",
    "FR-03": "taskq.cli.cli"
  },
  "architecture_constraints": [
    "no_circular_dependencies",
    "no_shell_true_anywhere",
    "stdlib_only",
    "single_io_site"
  ],
  "high_risk_modules": [
    "taskq.runner.runner",
    "taskq.io.store"
  ]
}