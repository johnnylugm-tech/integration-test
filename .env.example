# taskq environment variable defaults
# Copy to .env and edit to override.

# Directory where tasks.json is persisted. Default: $HOME/.taskq
TASKQ_HOME=.taskq

# Subprocess timeout in seconds. Default: 10.0
TASKQ_TASK_TIMEOUT=10.0

# Number of automatic retries on failed/timeout. Default: 2
TASKQ_RETRY_LIMIT=2
