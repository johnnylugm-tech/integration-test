# taskq environment configuration — copy to .env and adjust as needed
# All 8 TASKQ_* variables with their defaults (NFR-06)

# Directory where taskq stores its data files (tasks.json, breaker.json, cache.json)
TASKQ_HOME=.taskq

# Maximum number of concurrent worker threads for run-all
TASKQ_MAX_WORKERS=4

# Per-task subprocess timeout in seconds
TASKQ_TASK_TIMEOUT=10.0

# Number of retry attempts after a failed/timeout task (0 = no retries)
TASKQ_RETRY_LIMIT=2

# Base delay in seconds for exponential backoff between retries
TASKQ_BACKOFF_BASE=0.1

# Number of consecutive final failures before the circuit breaker opens
TASKQ_BREAKER_THRESHOLD=3

# Seconds the circuit breaker stays OPEN before transitioning to HALF_OPEN
TASKQ_BREAKER_COOLDOWN=5.0

# TTL in seconds for cached task results (used with --cached flag)
TASKQ_CACHE_TTL=3600
